config login 'main'
	option enabled '0'
	option portal_url 'http://192.168.16.3/'
	option login_path '/drcom/login'
	option logout_path '/drcom/logout'
	option username ''
	option password ''

	# Supported aliases: none, campus, teacher, continuing, cmcc, mobile,
	# unicom, lt, telecom, dx, or a literal suffix such as @cmcc.
	option operator 'cmcc'

	option check_interval '15'
	option login_retry_interval '60'
	option connect_timeout '5'
	option max_time '10'
	option user_agent 'Mozilla/5.0 (OpenWrt; ruijie-campus-autologin)'

	# Optional external probe. Leave empty to judge only from the portal page.
	option probe_url 'http://connectivitycheck.gstatic.com/generate_204'
	option probe_expect_code '204'

	# Extra form fields copied from the demo page.
	option mkkey '123456'
	option callback 'dr1003'
	option terminal_type '1'
	option lang 'zh'
	option js_version '4.1.3'
	option v '7651'
	option para '00'
	option r1 '0'
	option r2 ''
	option r3 '0'
	option r6 '0'

	# Remote stop commands. When SSH access is enabled on WAN, run:
	#   ruijie-campus-autologin-remote stop-autologin
	# Multiple commands are supported.
	list remote_command 'stop-autologin'
	list remote_command 'disable-autologin'

	# Standalone WebUI. Keep disabled unless it is needed.
	option webui_enabled '0'
	option webui_port '9099'
	option webui_listen_lan '1'
	option webui_listen_wan '0'
	option webui_username 'admin'
	option webui_password ''
	option webui_session_ttl '3600'

	# Version update settings.
	option update_check_enabled '0'
	option update_check_interval '86400'
	option update_auto_install '0'
	option update_source 'github'
	option update_mirror_url ''
	option github_repo 'LingRadiance/openwrt-ruijie-campus-autologin'
