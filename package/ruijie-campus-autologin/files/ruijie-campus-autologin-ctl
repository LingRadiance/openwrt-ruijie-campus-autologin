#!/bin/sh

SERVICE_NAME="ruijie-campus-autologin"
CONFIG_NAME="ruijie-campus-autologin"
TMP_DIR="/tmp/$SERVICE_NAME"
STATUS_FILE="$TMP_DIR/status"
EVENT_LOG="$TMP_DIR/events.log"
COOKIE_JAR="$TMP_DIR/cookies.txt"
LOGOUT_BODY="$TMP_DIR/logout.html"
DETECT_BODY="$TMP_DIR/detect.html"
UPDATE_BODY="$TMP_DIR/update.json"
UPDATE_IPK="$TMP_DIR/update.ipk"
VERSION="1.1.0"

. /lib/functions.sh

json_escape() {
	printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/	/\\t/g'
}

load_config() {
	config_load "$CONFIG_NAME"
	config_get portal_url main portal_url "http://192.168.16.3/"
	config_get login_path main login_path "/drcom/login"
	config_get logout_path main logout_path "/drcom/logout"
	config_get probe_url main probe_url ""
	config_get probe_expect_code main probe_expect_code "204"
	config_get callback main callback "dr1003"
	config_get mkkey main mkkey "123456"
	config_get terminal_type main terminal_type "1"
	config_get js_version main js_version "4.1.3"
	config_get v main v "7651"
	config_get para main para "00"
	config_get connect_timeout main connect_timeout "5"
	config_get max_time main max_time "10"
	config_get user_agent main user_agent "Mozilla/5.0 (OpenWrt; ruijie-campus-autologin)"
	config_get update_source main update_source "github"
	config_get update_mirror_url main update_mirror_url ""
	config_get github_repo main github_repo "LingRadiance/openwrt-ruijie-campus-autologin"
	config_get_bool update_check_enabled main update_check_enabled 0
	config_get update_check_interval main update_check_interval "86400"
	config_get_bool update_auto_install main update_auto_install 0
	config_get_bool enabled main enabled 0
	config_get_bool webui_enabled main webui_enabled 0
}

print_status() {
	local running="0"
	local state="unknown"
	local message="No status yet"
	local account=""
	local updated=""
	local check_fail_count="0"
	local login_fail_count="0"
	local login_success_count="0"
	local next_retry="0"
	local cooldown_until="0"

	pgrep -f "/usr/bin/$SERVICE_NAME" >/dev/null 2>&1 && running="1"

	if [ -f "$STATUS_FILE" ]; then
		. "$STATUS_FILE"
	fi

	printf '{"running":%s,"state":"%s","message":"%s","account":"%s","updated":"%s","check_fail_count":%s,"login_fail_count":%s,"login_success_count":%s,"next_retry":%s,"cooldown_until":%s}\n' \
		"$running" \
		"$(json_escape "$state")" \
		"$(json_escape "$message")" \
		"$(json_escape "$account")" \
		"$(json_escape "$updated")" \
		"${check_fail_count:-0}" \
		"${login_fail_count:-0}" \
		"${login_success_count:-0}" \
		"${next_retry:-0}" \
		"${cooldown_until:-0}"
}

print_events() {
	local first=1 line ts state message

	printf '['
	if [ -f "$EVENT_LOG" ]; then
		tail -n 20 "$EVENT_LOG" | while IFS= read -r line; do
			ts="${line%% | *}"
			line="${line#* | }"
			state="${line%% | *}"
			message="${line#* | }"
			[ "$first" = "1" ] || printf ','
			first=0
			printf '{"time":"%s","state":"%s","message":"%s"}' \
				"$(json_escape "$ts")" \
				"$(json_escape "$state")" \
				"$(json_escape "$message")"
		done
	fi
	printf ']\n'
}

diagnose() {
	local running="0" portal_code="000" probe_code="" login_url logout_url status_json

	load_config
	pgrep -f "/usr/bin/$SERVICE_NAME" >/dev/null 2>&1 && running="1"
	login_url="${portal_url%/}$login_path"
	logout_url="${portal_url%/}$logout_path"

	portal_code="$(curl -sS -o /dev/null -w "%{http_code}" \
		-A "$user_agent" \
		--connect-timeout "$connect_timeout" \
		--max-time "$max_time" \
		"$portal_url" 2>/dev/null)"
	[ -n "$portal_code" ] || portal_code="000"

	if [ -n "$probe_url" ]; then
		probe_code="$(curl -sS -o /dev/null -w "%{http_code}" \
			-L \
			-A "$user_agent" \
			--connect-timeout "$connect_timeout" \
			--max-time "$max_time" \
			"$probe_url" 2>/dev/null)"
		[ -n "$probe_code" ] || probe_code="000"
	fi

	status_json="$(print_status)"
	printf '{"ok":true,"running":%s,"portal_url":"%s","login_url":"%s","logout_url":"%s","portal_http_code":"%s","probe_url":"%s","probe_http_code":"%s","probe_expect_code":"%s","status":%s}\n' \
		"$running" \
		"$(json_escape "$portal_url")" \
		"$(json_escape "$login_url")" \
		"$(json_escape "$logout_url")" \
		"$(json_escape "$portal_code")" \
		"$(json_escape "$probe_url")" \
		"$(json_escape "$probe_code")" \
		"$(json_escape "$probe_expect_code")" \
		"$status_json"
}

logout() {
	local logout_url

	load_config
	mkdir -p "$TMP_DIR"
	touch "$COOKIE_JAR"
	logout_url="${portal_url%/}$logout_path"

	if curl -fsSL \
		-A "$user_agent" \
		--connect-timeout "$connect_timeout" \
		--max-time "$max_time" \
		-b "$COOKIE_JAR" \
		-c "$COOKIE_JAR" \
		-o "$LOGOUT_BODY" \
		--get \
		--data-urlencode "callback=$callback" \
		--data-urlencode "jsVersion=4.1.3" \
		--data-urlencode "v=7651" \
		--data-urlencode "lang=zh" \
		"$logout_url"; then
		cat > "$STATUS_FILE" <<-EOF
state='logged_out'
message='Logout request sent'
account=''
updated='$(date "+%Y-%m-%d %H:%M:%S")'
check_fail_count='0'
login_fail_count='0'
login_success_count='0'
next_retry='0'
cooldown_until='0'
EOF
		printf '%s | %s | %s\n' "$(date "+%Y-%m-%d %H:%M:%S")" "logged_out" "Logout request sent" >> "$EVENT_LOG"
		printf '{"ok":true,"message":"Logout request sent"}\n'
	else
		printf '{"ok":false,"message":"Logout request failed"}\n'
		return 1
	fi
}

first_match() {
	local pattern="$1"
	local file="$2"

	grep -Eo "$pattern" "$file" 2>/dev/null | head -n 1
}

strip_js_value() {
	sed "s/^[^'\"]*['\"]//; s/['\"].*$//"
}

strip_html_value() {
	sed 's/^.*value=["'\'']//; s/["'\''].*$//'
}

detect_value_or_current() {
	local detected="$1"
	local current="$2"

	if [ -n "$detected" ]; then
		printf '%s' "$detected"
	else
		printf '%s' "$current"
	fi
}

autodetect() {
	local detected_login_path detected_logout_path detected_mkkey
	local detected_callback detected_terminal_type detected_js_version
	local detected_v detected_para random_v

	load_config
	mkdir -p "$TMP_DIR"

	if ! curl -fsSL \
		-A "$user_agent" \
		--connect-timeout "$connect_timeout" \
		--max-time "$max_time" \
		-o "$DETECT_BODY" \
		"$portal_url"; then
		printf '{"ok":false,"message":"Failed to fetch portal page"}\n'
		return 1
	fi

	if grep -q "Dr.COMWebLoginID" "$DETECT_BODY" 2>/dev/null || grep -q "/drcom/login" "$DETECT_BODY" 2>/dev/null; then
		detected_login_path="/drcom/login"
	else
		detected_login_path="$(first_match "authloginpath[[:space:]]*=[[:space:]]*['\"][^'\"]+" "$DETECT_BODY" | strip_js_value)"
	fi

	if grep -q "Dr.COMWebLoginID" "$DETECT_BODY" 2>/dev/null || grep -q "/drcom/logout" "$DETECT_BODY" 2>/dev/null; then
		detected_logout_path="/drcom/logout"
	else
		detected_logout_path="$(first_match "authlogoutpath[[:space:]]*=[[:space:]]*['\"][^'\"]+" "$DETECT_BODY" | strip_js_value)"
	fi

	detected_mkkey="$(first_match "name=['\"]0MKKey['\"][^>]*value=['\"][^'\"]*" "$DETECT_BODY" | strip_html_value)"
	[ -n "$detected_mkkey" ] || detected_mkkey="$(first_match "0MKKey[=:'\"][[:space:]]*['\"]?[0-9A-Za-z_-]+" "$DETECT_BODY" | sed "s/^.*[=:'\"]//")"

	detected_para="$(first_match "name=['\"]para['\"][^>]*value=['\"][^'\"]*" "$DETECT_BODY" | strip_html_value)"
	[ -n "$detected_para" ] || detected_para="$(first_match "para[=:'\"][[:space:]]*['\"]?[0-9A-Za-z_-]+" "$DETECT_BODY" | sed "s/^.*[=:'\"]//")"

	detected_terminal_type="$(first_match "terminal_type[=:'\"][[:space:]]*['\"]?[0-9]+" "$DETECT_BODY" | sed "s/^.*[=:'\"]//")"
	[ -n "$detected_terminal_type" ] || detected_terminal_type="$(first_match "terminalidentity[[:space:]]*=[[:space:]]*[0-9]+" "$DETECT_BODY" | sed 's/^.*=//; s/[[:space:]]//g')"

	detected_callback="$(first_match "callback[=:'\"][[:space:]]*['\"]?dr[0-9]+" "$DETECT_BODY" | sed "s/^.*[=:'\"]//")"
	[ -n "$detected_callback" ] || detected_callback="$callback"

	detected_js_version="$(first_match "jsVersion[=:'\"][[:space:]]*['\"]?[0-9][0-9.]*" "$DETECT_BODY" | sed "s/^.*[=:'\"]//")"
	[ -n "$detected_js_version" ] || detected_js_version="$js_version"

	detected_v="$(first_match "[?&]v=[0-9]+" "$DETECT_BODY" | sed 's/^.*=//')"
	if [ -z "$detected_v" ]; then
		random_v="$(date +%s)"
		detected_v=$((random_v % 9000 + 1000))
	fi

	login_path="$(detect_value_or_current "$detected_login_path" "$login_path")"
	logout_path="$(detect_value_or_current "$detected_logout_path" "$logout_path")"
	mkkey="$(detect_value_or_current "$detected_mkkey" "$mkkey")"
	terminal_type="$(detect_value_or_current "$detected_terminal_type" "$terminal_type")"
	js_version="$(detect_value_or_current "$detected_js_version" "$js_version")"
	v="$(detect_value_or_current "$detected_v" "$v")"
	para="$(detect_value_or_current "$detected_para" "$para")"
	callback="$(detect_value_or_current "$detected_callback" "$callback")"

	uci set "$CONFIG_NAME.main.login_path=$login_path"
	uci set "$CONFIG_NAME.main.logout_path=$logout_path"
	uci set "$CONFIG_NAME.main.mkkey=$mkkey"
	uci set "$CONFIG_NAME.main.callback=$callback"
	uci set "$CONFIG_NAME.main.terminal_type=$terminal_type"
	uci set "$CONFIG_NAME.main.js_version=$js_version"
	uci set "$CONFIG_NAME.main.v=$v"
	uci set "$CONFIG_NAME.main.para=$para"
	uci commit "$CONFIG_NAME"

	printf '{"ok":true,"login_path":"%s","logout_path":"%s","mkkey":"%s","callback":"%s","terminal_type":"%s","js_version":"%s","v":"%s","para":"%s"}\n' \
		"$(json_escape "$login_path")" \
		"$(json_escape "$logout_path")" \
		"$(json_escape "$mkkey")" \
		"$(json_escape "$callback")" \
		"$(json_escape "$terminal_type")" \
		"$(json_escape "$js_version")" \
		"$(json_escape "$v")" \
		"$(json_escape "$para")"
}

version_info() {
	printf '{"current":"%s","repo":"%s","source":"%s"}\n' \
		"$(json_escape "$VERSION")" \
		"$(json_escape "$github_repo")" \
		"$(json_escape "$update_source")"
}

extract_json_string() {
	local key="$1"
	sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p" | head -n 1
}

github_latest() {
	local api tag asset url

	api="https://api.github.com/repos/$github_repo/releases/latest"
	curl -fsSL \
		-A "$user_agent" \
		--connect-timeout "$connect_timeout" \
		--max-time "$max_time" \
		-o "$UPDATE_BODY" \
		"$api" || return 1

	tag="$(extract_json_string tag_name < "$UPDATE_BODY")"
	asset="$(grep -o 'https://[^"]*ruijie-campus-autologin_[^"]*\.ipk' "$UPDATE_BODY" | head -n 1)"
	[ -n "$asset" ] || return 1

	printf '%s\n%s\n' "$tag" "$asset"
}

mirror_latest() {
	local meta_url tag url

	[ -n "$update_mirror_url" ] || return 1
	meta_url="${update_mirror_url%/}/latest.json"
	curl -fsSL \
		-A "$user_agent" \
		--connect-timeout "$connect_timeout" \
		--max-time "$max_time" \
		-o "$UPDATE_BODY" \
		"$meta_url" || return 1

	tag="$(extract_json_string tag < "$UPDATE_BODY")"
	url="$(extract_json_string ipk_url < "$UPDATE_BODY")"
	[ -n "$tag" ] && [ -n "$url" ] || return 1
	printf '%s\n%s\n' "$tag" "$url"
}

latest_update() {
	load_config
	case "$update_source" in
		mirror) mirror_latest ;;
		*) github_latest ;;
	esac
}

check_update() {
	local info tag url

	info="$(latest_update)" || {
		printf '{"ok":false,"message":"Failed to check update","current":"%s"}\n' "$(json_escape "$VERSION")"
		return 1
	}
	tag="$(printf '%s\n' "$info" | sed -n '1p')"
	url="$(printf '%s\n' "$info" | sed -n '2p')"
	printf '{"ok":true,"current":"%s","latest":"%s","ipk_url":"%s","has_update":%s}\n' \
		"$(json_escape "$VERSION")" \
		"$(json_escape "$tag")" \
		"$(json_escape "$url")" \
		"$([ "v$VERSION" != "$tag" ] && [ "$VERSION" != "$tag" ] && echo true || echo false)"
}

install_update() {
	local info url

	info="$(latest_update)" || {
		printf '{"ok":false,"message":"Failed to check update"}\n'
		return 1
	}
	url="$(printf '%s\n' "$info" | sed -n '2p')"
	curl -fsSL \
		-A "$user_agent" \
		--connect-timeout "$connect_timeout" \
		--max-time 120 \
		-o "$UPDATE_IPK" \
		"$url" || {
			printf '{"ok":false,"message":"Failed to download update"}\n'
			return 1
		}
	if opkg install "$UPDATE_IPK" >/tmp/ruijie-campus-autologin-update.log 2>&1; then
		printf '{"ok":true,"message":"Update installed"}\n'
	else
		printf '{"ok":false,"message":"Update install failed","log":"%s"}\n' \
			"$(json_escape "$(tail -n 10 /tmp/ruijie-campus-autologin-update.log 2>/dev/null)")"
		return 1
	fi
}

configure_cron() {
	local cron_file="/etc/crontabs/root"
	local minutes command tmp

	load_config
	touch "$cron_file"
	sed -i '\#/usr/bin/ruijie-campus-autologin-ctl scheduled-update#d' "$cron_file"

	if [ "$update_check_enabled" = "1" ]; then
		minutes=$((update_check_interval / 60))
		[ "$minutes" -lt 5 ] && minutes=5
		command="/usr/bin/ruijie-campus-autologin-ctl scheduled-update >/dev/null 2>&1"
		echo "*/$minutes * * * * $command" >> "$cron_file"
	fi

	/etc/init.d/cron restart >/dev/null 2>&1 || true
	printf '{"ok":true}\n'
}

scheduled_update() {
	load_config
	[ "$update_check_enabled" = "1" ] || exit 0
	[ "$update_auto_install" = "1" ] || exit 0
	install_update >/dev/null 2>&1 || true
}

apply_settings() {
	load_config
	configure_cron >/dev/null 2>&1 || true

	if [ "$enabled" = "1" ]; then
		/etc/init.d/ruijie-campus-autologin enable >/dev/null 2>&1 || true
		/etc/init.d/ruijie-campus-autologin restart >/dev/null 2>&1 || true
	else
		/etc/init.d/ruijie-campus-autologin stop >/dev/null 2>&1 || true
	fi

	if [ "$webui_enabled" = "1" ]; then
		/etc/init.d/ruijie-campus-autologin-webui enable >/dev/null 2>&1 || true
		/etc/init.d/ruijie-campus-autologin-webui restart >/dev/null 2>&1 || true
	else
		/etc/init.d/ruijie-campus-autologin-webui stop >/dev/null 2>&1 || true
	fi

	printf '{"ok":true}\n'
}

case "$1" in
	status)
		print_status
		;;
	events)
		print_events
		;;
	diagnose)
		diagnose
		;;
	logout)
		logout
		;;
	autodetect)
		autodetect
		;;
	version)
		load_config
		version_info
		;;
	check-update)
		check_update
		;;
	install-update)
		install_update
		;;
	configure-cron)
		configure_cron
		;;
	scheduled-update)
		scheduled_update
		;;
	apply-settings)
		apply_settings
		;;
	*)
		printf 'Usage: %s {status|events|diagnose|logout|autodetect|version|check-update|install-update|configure-cron|scheduled-update|apply-settings}\n' "$0" >&2
		exit 1
		;;
esac
